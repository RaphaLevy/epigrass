################################################################
#
#  EPIGRASS - Model Definition
#  SEIRS-SEI Malaria Model for Manaus
#  Custom model with climate integration
#
################################################################

#==============================================================#
[THE WORLD]
#==============================================================#

sites = sites_manaus.csv
edges = edges_manaus.csv
encoding = utf-8

#==============================================================#
[EPIDEMIOLOGICAL MODEL]
#==============================================================#
modtype = Custom

#==============================================================#
[MODEL PARAMETERS]
#==============================================================#

# Human parameters (SEIRS model)
beta = 0.0015
alpha = 1.0
sigma = 1/12
gamma = 1/180
omega = 1/365

# Vector parameters (SEI model)
mu_m = 1/30
a = 0.3
b1 = 0.5
b2 = 0.5

# Carrying capacity for mosquitoes
M = 500

#==============================================================#
[INITIAL CONDITIONS]
#==============================================================#

S = 0.99
E = 0
I = 0.01
R = 0

# Initial mosquito state
Sm = 200
Em = 0
Im = 0

#=============================================================#
[EPIDEMIC EVENTS]
#=============================================================#

seed = [(1302603,'I',5)]
Vaccinate = []
Quarantine = []
Intervention = []

#==============================================================#
[TRANSPORTATION MODEL]
#==============================================================#

doTransp = 1
stochastic = 1
speed = 0

#==============================================================#
[SIMULATION AND OUTPUT]
#==============================================================#

steps = 365

outdir = 

sqlout = 1

report = 0

Replicas = 0
RandSeed = 0
Batch = []

################################################################
################################################################